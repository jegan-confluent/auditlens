datalayers.py
gap-analysis.html
verifynews.sh
verifynew.sh
verify.sh
*.backup
audit_forwarder.py.backup.*
datalayersnew.py
project-brief.html
infra/backup/
.claude/diary/
deploy/terraform/aws/.terraform/
deploy/terraform/**/.terraform/
*.tfstate
*.tfstate.backup
.claude/
.playwright-mcp/
archive/
jk-skills-complete/
deploy/cloud/
flink/
.dev-docs/
tools/
AGENTS.md
FEATURES.md
claude-addon.sh
frontend/.next/
frontend/node_modules/
