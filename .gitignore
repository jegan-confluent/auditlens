# ============================================================================
# Confluent Audit Log Intelligence System - .gitignore v8.0
# ============================================================================

# CRITICAL: Secrets and credentials
# ============================================================================
.secrets
.secret
.env
.env.*
notifications.yml
actor_mappings.yml
schema-watcher/.env.example
install.local.yaml
install.*.local.yaml
*.install.local.yaml
secrets/
deploy/kubernetes/generated/
*.pem
*.key
*.crt
*.p12
*.pfx
*credentials.json
*service-account*.json

# Kafka/Confluent specific
.confluent/
confluent.properties
*.properties

# API keys and tokens
*api_key*
*api-key*
*apikey*
*secret*
# Exception: Python masking-utility modules are code, not secrets files
!src/forwarder/secrets_masking.py
*token*
*.token

# Backup files that might contain secrets
*.backup
*.bak
**/.backup
**/*.bak
**/*.backup
*.env.backup
*.secret
*.secrets

# Python
# ============================================================================
__pycache__/
*__pycache__*
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# `lib/` above is for Python distribution artifacts. The frontend has its
# own ./frontend/lib directory of TypeScript modules that must be tracked.
!frontend/lib/
!frontend/lib/**
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv

# Jupyter Notebook
.ipynb_checkpoints

# IDEs
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
# ============================================================================
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.pytest_cache/
htmlcov/

# Docker
# ============================================================================
*.log

# Kubernetes
*.kubeconfig
.terraform/
.terraform.lock.hcl

# Offsets and state
# ============================================================================
offsets.json
forwarder_offsets.json
dashboard/email_cache.json
*.offset
consumer_offsets/

# Logs
# ============================================================================
*.log
logs/
*.out

# Temporary files
# ============================================================================
tmp/
temp/
*.tmp

# Frontend local build/dependency artifacts
# ============================================================================
frontend/.next/
frontend/node_modules/
node_modules/
# TypeScript incremental compile cache — regenerated on build
frontend/tsconfig.tsbuildinfo
*.tsbuildinfo

# Local runtime data and databases
# ============================================================================
data/
*.db
*.db-wal
*.db-shm

# macOS
# ============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*

# Archives (might contain sensitive data)
# ============================================================================
*.zip
*.bundle
*.tar.gz
*.tgz

# Keep these files
# ============================================================================
!.gitkeep
!README.md
!LICENSE
!/.env.example

# Claude Code
logs/tokens-*.jsonl
logs/audit-*.jsonl
.claude/CLAUDE.local.md
# Runtime lock files recreated per session
.claude/*.lock
AUDIT_REPORT.md
DASHBOARD_GAP_ANALYSIS.md
docs/PHASE4_PREFLIGHT.md

