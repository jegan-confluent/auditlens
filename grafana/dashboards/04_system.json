{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "description": "AuditLens container memory, CPU, and service up-status",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "auditlens-prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {},
      "description": "Memory usage per container",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "auditlens-prometheus"},
          "expr": "container_memory_usage_bytes",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Container Memory",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "auditlens-prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {},
      "description": "CPU usage rate per container (5-minute window)",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "auditlens-prometheus"},
          "expr": "rate(container_cpu_usage_seconds_total[5m])",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Container CPU",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "auditlens-prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "textMode": "auto", "colorMode": "background", "graphMode": "none"},
      "description": "Current up/down status for all scraped services",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "auditlens-prometheus"},
          "expr": "up",
          "legendFormat": "{{job}}",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Service Up Status",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["auditlens"],
  "templating": {"list": []},
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "AuditLens — System",
  "uid": "auditlens-system",
  "version": 1
}
