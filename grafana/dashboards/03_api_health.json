{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "description": "AuditLens FastAPI request rate, error rate, and latency",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "auditlens-prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "options": {},
      "description": "Incoming HTTP requests per second (5-minute rate)",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "auditlens-prometheus"},
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{handler}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "auditlens-prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "options": {},
      "description": "5xx HTTP error rate per second (5-minute rate)",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "auditlens-prometheus"},
          "expr": "rate(http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "{{method}} {{handler}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "auditlens-prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "options": {},
      "description": "95th percentile HTTP response time (5-minute window)",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "auditlens-prometheus"},
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency",
          "refId": "A"
        }
      ],
      "title": "Response Time p95",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["auditlens"],
  "templating": {"list": []},
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "AuditLens — API Health",
  "uid": "auditlens-api",
  "version": 1
}
