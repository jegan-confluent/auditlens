#!/usr/bin/env bash
# AuditLens setup — single entry point.
#
# Detects missing prerequisites, offers to install them on supported OSes
# (Amazon Linux 2023, Ubuntu/Debian, macOS) and then hands off to
# scripts/bootstrap_auditlens.py with a clean environment. Designed to
# avoid the "run, fail, install one thing, run again" cycle.
#
# Non-interactive overrides:
#   AUDITLENS_AUTO_INSTALL=1   answer "yes" to every install prompt
#   AUDITLENS_NO_INSTALL=1     answer "no" to every install prompt
#   PYTHON=...                 override the python binary used after install
#
# Pipefail but no -e: we handle errors explicitly so the user never gets a
# silent exit mid-recovery.
set -uo pipefail

# ───────────────────────── Self-update on launch ─────────────────────────
# Top-of-script auto-pull so a stale clone gets the latest setup logic
# before any prereq checks run. Guard rails:
#
#   • Sentinel AUDITLENS_UPDATED=1 is exported just before we re-exec
#     ourselves after a successful pull, so the re-execed script skips
#     this block — no infinite loop.
#   • $1 == "--no-update" or AUDITLENS_NO_UPDATE=1 disables the check
#     entirely (CI, offline installs, when the operator is mid-debug).
#   • Every git call has a fast failure path: no git binary, no origin,
#     network error → we fall through silently / with one info line and
#     continue with the local copy. The wizard is the source of value;
#     the update is a convenience.
#
# Inline printf (no color helpers) because this block runs BEFORE any UI
# helpers / OS detection are defined.
if [ "${AUDITLENS_UPDATED:-}" = "1" ]; then
    : # We just re-execed after a successful pull — skip to setup.
elif [ "${1:-}" = "--no-update" ]; then
    # Consume the flag so the rest of the script (and the Python wizard
    # it hands off to) never sees an unknown argument.
    shift
elif [ "${AUDITLENS_NO_UPDATE:-}" = "1" ]; then
    : # Explicit env-var opt-out.
elif ! command -v git >/dev/null 2>&1; then
    : # No git, can't update.
else
    _UPDATE_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if ! git -C "$_UPDATE_SCRIPT_DIR" remote get-url origin >/dev/null 2>&1; then
        : # Not in a git repo with an origin (e.g. user untarred a release).
    elif ! git -C "$_UPDATE_SCRIPT_DIR" fetch origin main --quiet --depth=1 2>/dev/null; then
        # Network unreachable / private repo / corp proxy block.
        printf 'ℹ  Could not reach origin — running with local version.\n'
    else
        _LOCAL_SHA=$(git -C "$_UPDATE_SCRIPT_DIR" rev-parse HEAD 2>/dev/null || true)
        _REMOTE_SHA=$(git -C "$_UPDATE_SCRIPT_DIR" rev-parse origin/main 2>/dev/null || true)
        if [ -n "$_LOCAL_SHA" ] && [ -n "$_REMOTE_SHA" ] && [ "$_LOCAL_SHA" != "$_REMOTE_SHA" ]; then
            _REMOTE_SHORT=$(git -C "$_UPDATE_SCRIPT_DIR" rev-parse --short origin/main 2>/dev/null)
            printf '⬆  New version available (%s).\n' "$_REMOTE_SHORT"
            printf '   Pulling latest changes...\n'
            if git -C "$_UPDATE_SCRIPT_DIR" pull origin main --quiet; then
                _NEW_SHORT=$(git -C "$_UPDATE_SCRIPT_DIR" rev-parse --short HEAD)
                printf '✅  Updated to %s. Restarting...\n' "$_NEW_SHORT"
                export AUDITLENS_UPDATED=1
                exec "$0" "$@"
            else
                printf '⚠  Could not pull — running with current version.\n'
            fi
        fi
    fi
    unset _UPDATE_SCRIPT_DIR _LOCAL_SHA _REMOTE_SHA _REMOTE_SHORT _NEW_SHORT
fi

# ───────────────────────── Minimum versions ──────────────────────────────
PYTHON=${PYTHON:-python3}
PYTHON_MIN_MAJOR=3
PYTHON_MIN_MINOR=11
# Highest minor version AuditLens is regularly exercised on. Above this we
# fall through to a *dynamic* compatibility check: a `pip install --dry-run`
# inside the freshly-created venv tells us authoritatively whether every
# pinned dep has a wheel for the current Python. Self-healing — when
# pydantic-core ships 3.15 wheels next year, the bump happens automatically
# with no code change. Historical context: psycopg-binary 3.1.x lacked 3.14
# wheels on day one, which is exactly the class of failure the dry-run
# catches up front instead of mid-`pip install`.
PYTHON_MAX_TESTED_MINOR=13
DOCKER_MIN_MAJOR=20
DOCKER_MIN_MINOR=10
COMPOSE_MIN_MAJOR=2
COMPOSE_MIN_MINOR=0
MIN_DISK_GB=2
REQUIRED_PORTS=(80 443 8003)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ───────────────────────── UI helpers ────────────────────────────────────
if [ -t 1 ]; then
    GREEN=$'\033[0;32m'; RED=$'\033[0;31m'; YELLOW=$'\033[0;33m'; BLUE=$'\033[0;34m'; NC=$'\033[0m'
else
    GREEN=""; RED=""; YELLOW=""; BLUE=""; NC=""
fi
ok()   { printf '%b✅%b  %s\n' "$GREEN" "$NC" "$*"; }
warn() { printf '%b⚠%b  %s\n'  "$YELLOW" "$NC" "$*"; }
fail() { printf '%b❌%b  %s\n'  "$RED"   "$NC" "$*"; }
info() { printf '%bℹ%b  %s\n'  "$BLUE"  "$NC" "$*"; }

# prompt_yn QUESTION [DEFAULT_Y_OR_N]
#   Echoes "Y" or "N". Honours AUDITLENS_AUTO_INSTALL / AUDITLENS_NO_INSTALL.
#   In non-interactive shells (no tty) returns the default.
prompt_yn() {
    local question="$1" default="${2:-Y}"
    if [ "${AUDITLENS_AUTO_INSTALL:-}" = "1" ]; then echo "Y"; return; fi
    if [ "${AUDITLENS_NO_INSTALL:-}"   = "1" ]; then echo "N"; return; fi
    if [ ! -t 0 ] && [ ! -r /dev/tty ]; then echo "$default"; return; fi
    local hint="[Y/n]"; [ "$default" = "N" ] && hint="[y/N]"
    local ans=""
    if [ -r /dev/tty ]; then
        read -r -p "$question $hint " ans </dev/tty
    else
        read -r -p "$question $hint " ans
    fi
    ans=${ans:-$default}
    case "$ans" in [Yy]|[Yy][Ee][Ss]) echo "Y" ;; *) echo "N" ;; esac
}

# ───────────────────────── OS detection ──────────────────────────────────
OS=unknown; PKG_MGR=""; OS_PRETTY="unknown"
detect_os() {
    case "$(uname -s)" in
        Darwin) OS=macos; PKG_MGR=brew; OS_PRETTY="macOS $(sw_vers -productVersion 2>/dev/null || echo)" ;;
        Linux)
            if [ -r /etc/os-release ]; then
                # shellcheck disable=SC1091
                . /etc/os-release
                OS_PRETTY="${PRETTY_NAME:-Linux}"
                case "${ID:-}" in
                    amzn)            OS=amzn;   PKG_MGR=dnf ;;
                    ubuntu)          OS=ubuntu; PKG_MGR=apt ;;
                    debian)          OS=debian; PKG_MGR=apt ;;
                    rhel|centos|fedora) OS=rhel; PKG_MGR=dnf ;;
                    *)               OS=linux-unknown; PKG_MGR="" ;;
                esac
            else
                OS=linux-unknown; OS_PRETTY="Linux (unknown distro)"
            fi
            ;;
        MINGW*|CYGWIN*|MSYS*) OS=windows; OS_PRETTY="Windows" ;;
        *) OS=unknown; OS_PRETTY="$(uname -s)" ;;
    esac
}

# ───────────────────────── Banner + prereqs list ─────────────────────────
print_banner() {
    echo ""
    echo "╔══════════════════════════════════════╗"
    echo "║        AuditLens Setup               ║"
    echo "╚══════════════════════════════════════╝"
    echo ""
    info "Detected OS: $OS_PRETTY"
    echo ""
    echo "AuditLens requires:"
    echo "  • Python ${PYTHON_MIN_MAJOR}.${PYTHON_MIN_MINOR}+"
    echo "  • Docker ${DOCKER_MIN_MAJOR}.${DOCKER_MIN_MINOR}+"
    echo "  • Docker Compose ${COMPOSE_MIN_MAJOR}.${COMPOSE_MIN_MINOR}+"
    echo "  • Git"
    echo "  • ${MIN_DISK_GB}GB+ free disk space"
    echo "  • Ports ${REQUIRED_PORTS[*]} available"
    echo ""
}

# ───────────────────────── Python ────────────────────────────────────────
PYTHON_VERSION_STR=""
check_python() {
    # Try every plausible interpreter name and pick the first that meets the
    # version floor. Earlier versions of this script trusted whatever `python3`
    # pointed at; on systems where the default `python3` is 3.9 (Amazon Linux
    # 2023, older macOS), the version check then failed even when a separate
    # `python3.11` binary existed from a prior install. Iterating the full
    # candidate list every run keeps the prereq state honest after a session
    # install.
    PYTHON_VERSION_STR=""
    local candidates=("$PYTHON" python3.13 python3.12 python3.11 python3)
    local seen_version=""
    for cand in "${candidates[@]}"; do
        command -v "$cand" >/dev/null 2>&1 || continue
        local maj min full
        maj=$("$cand" -c 'import sys; print(sys.version_info.major)' 2>/dev/null) || continue
        min=$("$cand" -c 'import sys; print(sys.version_info.minor)' 2>/dev/null) || continue
        full=$("$cand" -c 'import sys; print(".".join(map(str, sys.version_info[:3])))' 2>/dev/null)
        # Capture the highest version we've seen for the error message even
        # when nothing qualifies.
        [ -z "$seen_version" ] && seen_version="$full"
        if [ "$maj" -gt "$PYTHON_MIN_MAJOR" ] || \
           { [ "$maj" -eq "$PYTHON_MIN_MAJOR" ] && [ "$min" -ge "$PYTHON_MIN_MINOR" ]; }; then
            PYTHON="$cand"
            PYTHON_VERSION_STR="$full"
            return 0
        fi
    done
    PYTHON_VERSION_STR="$seen_version"
    return 1
}

install_python() {
    info "Installing Python ${PYTHON_MIN_MAJOR}.${PYTHON_MIN_MINOR}…"
    case "$OS" in
        amzn|rhel)
            sudo dnf install -y python3.11 python3.11-pip || return 1 ;;
        ubuntu|debian)
            sudo apt-get update -y && sudo apt-get install -y python3.11 python3.11-venv python3.11-distutils || return 1 ;;
        macos)
            command -v brew >/dev/null 2>&1 || {
                fail "Homebrew not found. Install brew from https://brew.sh and retry."
                return 1
            }
            brew install python@3.11 || return 1 ;;
        *)
            return 1 ;;
    esac
    # Prefer the freshly-installed interpreter on the next check.
    if   command -v python3.11 >/dev/null 2>&1; then PYTHON=python3.11
    elif command -v python3    >/dev/null 2>&1; then PYTHON=python3
    fi
    return 0
}

manual_install_python() {
    echo "  Manual install:"
    case "$OS" in
        amzn|rhel)     echo "    sudo dnf install -y python3.11 python3.11-pip" ;;
        ubuntu|debian) echo "    sudo apt-get install -y python3.11 python3.11-venv" ;;
        macos)         echo "    brew install python@3.11" ;;
        windows)       echo "    Install Python 3.${PYTHON_MIN_MINOR}+ from https://python.org/downloads" ;
                       echo "    (then re-run setup from a WSL2 Ubuntu terminal)" ;;
        *)             echo "    Install Python 3.${PYTHON_MIN_MINOR}+ for your OS." ;;
    esac
}

# ───────────────────────── Docker ────────────────────────────────────────
DOCKER_VERSION_STR=""
check_docker() {
    DOCKER_VERSION_STR=""
    command -v docker >/dev/null 2>&1 || return 1
    DOCKER_VERSION_STR=$(docker --version 2>/dev/null | awk '{print $3}' | tr -d ',')
    if ! docker info >/dev/null 2>&1; then return 2; fi   # installed but not running
    local maj min
    maj=$(printf '%s' "$DOCKER_VERSION_STR" | cut -d. -f1)
    min=$(printf '%s' "$DOCKER_VERSION_STR" | cut -d. -f2)
    [[ "$maj" =~ ^[0-9]+$ ]] || return 1
    [[ "$min" =~ ^[0-9]+$ ]] || return 1
    if [ "$maj" -gt "$DOCKER_MIN_MAJOR" ]; then return 0; fi
    if [ "$maj" -eq "$DOCKER_MIN_MAJOR" ] && [ "$min" -ge "$DOCKER_MIN_MINOR" ]; then return 0; fi
    return 1
}

install_docker() {
    info "Installing Docker…"
    case "$OS" in
        amzn|rhel)
            sudo dnf install -y docker || return 1
            # Combined enable + start. The previous two-step (start, then
            # enable) sometimes left the daemon stopped on AL2023 when the
            # first systemctl call failed silently — `--now` makes the
            # success/failure atomic and is the idiomatic command.
            sudo systemctl enable --now docker \
                || warn "Could not enable+start docker via systemctl — check 'sudo systemctl status docker'"
            if [ "$(id -u)" -ne 0 ] && id -nG "$USER" | grep -qvw docker; then
                sudo usermod -aG docker "$USER" || true
                warn "Added $USER to the 'docker' group. Log out and back in (or run 'newgrp docker') for the group to take effect in this shell."
            fi
            ;;
        ubuntu|debian)
            sudo apt-get update -y && sudo apt-get install -y docker.io docker-compose-plugin || return 1
            sudo systemctl enable --now docker \
                || warn "Could not enable+start docker via systemctl — check 'sudo systemctl status docker'"
            if [ "$(id -u)" -ne 0 ] && id -nG "$USER" | grep -qvw docker; then
                sudo usermod -aG docker "$USER" || true
                warn "Added $USER to the 'docker' group. Log out and back in (or run 'newgrp docker') for the group to take effect in this shell."
            fi
            ;;
        macos)
            fail "Docker Desktop must be installed manually on macOS."
            echo "    Download: https://docker.com/products/docker-desktop"
            echo "    After install, launch Docker Desktop and re-run ./setup."
            return 1
            ;;
        *)
            return 1
            ;;
    esac
    return 0
}

manual_install_docker() {
    echo "  Manual install:"
    case "$OS" in
        amzn|rhel)     echo "    sudo dnf install -y docker && sudo systemctl enable --now docker" ;;
        ubuntu|debian) echo "    sudo apt-get install -y docker.io docker-compose-plugin" ;;
        macos)         echo "    Download Docker Desktop from https://docker.com/products/docker-desktop" ;;
        *)             echo "    Install Docker ${DOCKER_MIN_MAJOR}.${DOCKER_MIN_MINOR}+ for your OS." ;;
    esac
}

# ───────────────────────── Docker Compose v2 ─────────────────────────────
COMPOSE_VERSION_STR=""
_compose_version_ok() {
    local ver="$1"
    local maj min
    maj=$(printf '%s' "$ver" | cut -d. -f1)
    min=$(printf '%s' "$ver" | cut -d. -f2)
    [[ "$maj" =~ ^[0-9]+$ ]] || return 1
    [[ "$min" =~ ^[0-9]+$ ]] || return 1
    if [ "$maj" -gt "$COMPOSE_MIN_MAJOR" ]; then return 0; fi
    if [ "$maj" -eq "$COMPOSE_MIN_MAJOR" ] && [ "$min" -ge "$COMPOSE_MIN_MINOR" ]; then return 0; fi
    return 1
}

check_compose() {
    # Accept either Compose v2 (docker subcommand) or v1 (standalone binary)
    # at runtime — both expose `docker-compose-like` commands and both
    # satisfy the 2.0+ floor. Probing `--version` keeps the check honest
    # after a session install rather than caching first-call state.
    COMPOSE_VERSION_STR=""
    if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
        COMPOSE_VERSION_STR=$(docker compose version --short 2>/dev/null)
        if _compose_version_ok "$COMPOSE_VERSION_STR"; then return 0; fi
    fi
    if command -v docker-compose >/dev/null 2>&1; then
        # `docker-compose --version` → "Docker Compose version v2.20.0" (v2)
        # or "docker-compose version 1.29.2, build ..." (v1). Strip the
        # leading "v" if present.
        local v1
        v1=$(docker-compose --version 2>/dev/null | awk '{for (i=1; i<=NF; i++) if ($i ~ /[0-9]+\.[0-9]+/) {print $i; exit}}' | tr -d 'v,')
        if [ -n "$v1" ]; then
            COMPOSE_VERSION_STR="$v1"
            if _compose_version_ok "$v1"; then return 0; fi
        fi
    fi
    return 1
}

install_compose() {
    info "Installing Docker Compose v2…"
    case "$OS" in
        amzn|rhel)
            # Amazon Linux 2023 ships compose v2 bundled with Docker as a
            # `docker compose` subcommand — there is no docker-compose-plugin
            # package. If the subcommand already works (e.g. Docker was just
            # installed by this script a few lines up), we're done. Only
            # fall back to the manual plugin download when it doesn't.
            if docker compose version >/dev/null 2>&1; then
                info "Compose v2 already available via the docker subcommand — no separate install needed."
                return 0
            fi
            local plugin_arch plugin_dir
            case "$(uname -m)" in
                x86_64)         plugin_arch=x86_64 ;;
                aarch64|arm64)  plugin_arch=aarch64 ;;
                *)              fail "Unsupported architecture for compose plugin: $(uname -m)"; return 1 ;;
            esac
            plugin_dir=${DOCKER_CONFIG:-$HOME/.docker}/cli-plugins
            mkdir -p "$plugin_dir" || return 1
            if ! curl -fSL \
                "https://github.com/docker/compose/releases/latest/download/docker-compose-linux-${plugin_arch}" \
                -o "$plugin_dir/docker-compose"; then
                fail "Failed to download docker-compose plugin from GitHub releases"
                return 1
            fi
            chmod +x "$plugin_dir/docker-compose"
            ;;
        ubuntu|debian) sudo apt-get install -y docker-compose-plugin || return 1 ;;
        macos)
            fail "Docker Compose v2 ships with Docker Desktop on macOS. Update Docker Desktop."
            return 1 ;;
        *)             return 1 ;;
    esac
}

manual_install_compose() {
    echo "  Manual install:"
    case "$OS" in
        amzn|rhel)
            # AL2023 has no docker-compose-plugin package — point users at the
            # bundled-with-docker subcommand or the official static download.
            echo "    Compose v2 ships bundled with Docker on Amazon Linux 2023."
            echo "    Run: sudo dnf install -y docker && sudo systemctl enable --now docker"
            echo "    Then: docker compose version  (should report 2.x)"
            echo "    Fallback (manual plugin download):"
            echo "      mkdir -p \$HOME/.docker/cli-plugins"
            echo "      curl -SL https://github.com/docker/compose/releases/latest/download/docker-compose-linux-\$(uname -m) \\"
            echo "        -o \$HOME/.docker/cli-plugins/docker-compose"
            echo "      chmod +x \$HOME/.docker/cli-plugins/docker-compose"
            ;;
        ubuntu|debian) echo "    sudo apt-get install -y docker-compose-plugin" ;;
        macos)         echo "    Update Docker Desktop (ships with Compose v2)" ;;
        *)             echo "    Install docker-compose-plugin (v2) for your OS." ;;
    esac
}

# ───────────────────────── ensure_* drivers ──────────────────────────────
# Each driver: check → if missing, ask → install → re-check → fail with manual cmd.
ensure_python() {
    if check_python; then
        ok "Python $PYTHON_VERSION_STR"
        return 0
    fi
    fail "Python ${PYTHON_MIN_MAJOR}.${PYTHON_MIN_MINOR}+ not found${PYTHON_VERSION_STR:+ (found $PYTHON_VERSION_STR)}."
    if [ "$(prompt_yn "Install it automatically?" Y)" != "Y" ]; then
        manual_install_python; exit 1
    fi
    if ! install_python; then
        fail "Automatic install failed."
        manual_install_python; exit 1
    fi
    if ! check_python; then
        fail "Python ${PYTHON_MIN_MAJOR}.${PYTHON_MIN_MINOR}+ still not detected after install."
        manual_install_python; exit 1
    fi
    ok "Python $PYTHON_VERSION_STR (installed)"
}

# Dynamic dep-compatibility check, called inside ensure_python_deps once the
# venv exists. For Python ≤ PYTHON_MAX_TESTED_MINOR (3.13 today) this is a
# silent no-op — the dep set is regularly exercised on those versions.
#
# For Python > PYTHON_MAX_TESTED_MINOR we run `pip install --dry-run
# --only-binary=:all: -r requirements-setup.txt` against the *real* venv
# pip. `--only-binary=:all:` is critical: without it, pip's dry-run reports
# success whenever an sdist (.tar.gz) exists on PyPI — even if no wheel
# is available for the current Python, which then crashes the real
# install at C/C++ build time. Forcing binary-only resolution makes the
# dry-run fail fast on exactly the class of error we are gating against,
# and the operator gets a clean "use Python 3.12 or 3.13" exit instead of
# a stack-trace from gcc.
#
# Args: $1 = venv directory (so we use the venv's pip, not the system one).
#       $2 = path to requirements-setup.txt (the wizard-only dep list).
#       $3 = venv Python version string (e.g. "3.14.0") — passed in by the
#            caller so we gate on the *venv* Python, not whatever the system
#            `python3` happens to point at. The two can diverge when a
#            pre-existing .venv was created with a different interpreter.
#       $4 = venv Python minor version as an integer (e.g. "14") — derived
#            from `sys.version_info.minor` on the venv interpreter, again so
#            the gate matches the actual pip target, not the system Python.
#
# This replaces the previous static soft-warn — same trigger point (Python
# above the tested ceiling) but the verdict comes from pip's own resolver
# rather than a hand-maintained version list.
check_python_dep_compat() {
    local venv_dir="$1" req="$2" venv_python_version="$3" venv_minor="$4"
    [[ "$venv_minor" =~ ^[0-9]+$ ]] || return 0
    if [ "$venv_minor" -le "$PYTHON_MAX_TESTED_MINOR" ]; then
        return 0
    fi
    warn "Python ${venv_python_version}+ detected (venv). Checking dependency compatibility…"
    # Upgrade pip first so its resolver understands the latest wheel formats.
    # Failure here is non-fatal — the bundled pip is often new enough.
    "$venv_dir/bin/pip" install --upgrade pip >/dev/null 2>&1 || true
    local dry_run_output dry_run_rc
    # --only-binary=:all: refuses sdist fallback so the dry-run actually
    # gates on wheel availability instead of waving through packages that
    # only ship a source distribution.
    dry_run_output=$("$venv_dir/bin/pip" install --dry-run --only-binary=:all: -r "$req" 2>&1)
    dry_run_rc=$?
    if [ "$dry_run_rc" -eq 0 ]; then
        ok "Dependencies compatible with Python ${venv_python_version}. Continuing."
        return 0
    fi
    fail "One or more dependencies are not yet compatible with Python ${venv_python_version}."
    echo "  Incompatible packages:"
    # pip emits either "No matching distribution found for X" or
    # "Could not find a version that satisfies the requirement X" — capture
    # both. Fall back to a generic note if neither pattern matched (e.g.
    # pip surfaced a build error or a resolver conflict).
    local failing
    failing=$(printf '%s\n' "$dry_run_output" \
        | grep -E "No matching distribution found for|Could not find a version that satisfies" \
        | sed -E 's/.*(for|requirement) //' \
        | sort -u)
    if [ -n "$failing" ]; then
        printf '%s\n' "$failing" | sed 's/^/    • /'
    else
        echo "    (pip did not surface specific packages — see full output below)"
        printf '%s\n' "$dry_run_output" | tail -20 | sed 's/^/    /'
    fi
    echo "  Recommended: use Python 3.12 or 3.13."
    case "$OS" in
        macos)         echo "  Install via: brew install python@3.13" ;;
        amzn|rhel)     echo "  Install via: sudo dnf install -y python3.13" ;;
        ubuntu|debian) echo "  Install via: sudo apt-get install -y python3.13 python3.13-venv" ;;
        windows)       echo "  Install Python 3.13 from https://python.org/downloads (then re-run from WSL2)" ;;
        *)             echo "  Install Python 3.12 or 3.13 for your OS." ;;
    esac
    exit 1
}

ensure_docker() {
    check_docker; local rc=$?
    if [ "$rc" -eq 0 ]; then
        # Daemon is up — distinguish Docker Desktop (mac) vs Engine (linux)
        # so the operator sees what they're actually running. `docker info`
        # exposes "Operating System: Docker Desktop" on Desktop installs.
        if [ "$OS" = "macos" ]; then
            if docker info 2>/dev/null | grep -qi "docker desktop"; then
                ok "Docker Desktop $DOCKER_VERSION_STR (running)"
            else
                ok "Docker $DOCKER_VERSION_STR (engine — Docker Desktop not detected)"
            fi
        else
            # On Linux, verify systemd thinks the unit is active too. A
            # `docker info` success with a non-active unit can happen with
            # weird wrapper scripts; surface the inconsistency.
            if command -v systemctl >/dev/null 2>&1 && \
               ! systemctl is-active --quiet docker 2>/dev/null; then
                warn "Docker daemon answered but systemd reports it inactive."
                echo "  Try: sudo systemctl start docker"
            fi
            ok "Docker $DOCKER_VERSION_STR"
        fi
        return 0
    fi
    if [ "$rc" -eq 2 ]; then
        # Installed but daemon not running.
        fail "Docker is installed (v$DOCKER_VERSION_STR) but the daemon is not running."
        case "$OS" in
            macos)         echo "  Open Docker Desktop from Applications and wait for it to start," ;
                           echo "  then re-run ./setup." ;;
            amzn|rhel|ubuntu|debian|windows) echo "  Try:  sudo systemctl start docker" ;;
            *)             echo "  Start Docker for your OS and re-run ./setup." ;;
        esac
        exit 1
    fi
    fail "Docker not found."
    if [ "$(prompt_yn "Install it automatically?" Y)" != "Y" ]; then
        manual_install_docker; exit 1
    fi
    if ! install_docker; then
        fail "Automatic install failed."
        manual_install_docker; exit 1
    fi
    if ! check_docker; then
        fail "Docker still not usable after install. Make sure the daemon is running and your user is in the 'docker' group (logout/login may be required)."
        manual_install_docker; exit 1
    fi
    ok "Docker $DOCKER_VERSION_STR (installed)"
}

ensure_compose() {
    if check_compose; then ok "Docker Compose $COMPOSE_VERSION_STR"; return 0; fi
    fail "Docker Compose v${COMPOSE_MIN_MAJOR}.${COMPOSE_MIN_MINOR}+ not found${COMPOSE_VERSION_STR:+ (found $COMPOSE_VERSION_STR)}."
    if [ "$(prompt_yn "Install it automatically?" Y)" != "Y" ]; then
        manual_install_compose; exit 1
    fi
    if ! install_compose; then
        fail "Automatic install failed."
        manual_install_compose; exit 1
    fi
    if ! check_compose; then
        fail "Docker Compose still not usable after install."
        manual_install_compose; exit 1
    fi
    ok "Docker Compose $COMPOSE_VERSION_STR (installed)"
}

# Git is needed by any subsequent clone/pull flows in the bootstrap.
# Treat as a simple presence check; do not version-gate.
ensure_git() {
    if command -v git >/dev/null 2>&1; then ok "Git $(git --version | awk '{print $3}')"; return 0; fi
    fail "Git not found."
    if [ "$(prompt_yn "Install it automatically?" Y)" != "Y" ]; then
        echo "  Manual install: sudo $PKG_MGR install -y git  (or 'brew install git' on macOS)"
        exit 1
    fi
    case "$OS" in
        amzn|rhel)     sudo dnf install -y git ;;
        ubuntu|debian) sudo apt-get update -y && sudo apt-get install -y git ;;
        macos)         command -v brew >/dev/null && brew install git || true ;;
    esac
    command -v git >/dev/null 2>&1 || { fail "Git install failed."; exit 1; }
    ok "Git $(git --version | awk '{print $3}') (installed)"
}

# ───────────────────────── Disk space (hard-fail rule) ───────────────────
ensure_disk() {
    local target=$SCRIPT_DIR
    # df -k is portable across BSD and GNU. Field 4 = available 1K-blocks.
    local avail_kb
    avail_kb=$(df -k "$target" 2>/dev/null | awk 'NR==2 {print $4}')
    if ! [[ "$avail_kb" =~ ^[0-9]+$ ]]; then
        warn "Could not determine free disk space for $target — continuing."
        return 0
    fi
    local avail_gb=$(( avail_kb / 1024 / 1024 ))
    if [ "$avail_gb" -lt "$MIN_DISK_GB" ]; then
        fail "Insufficient disk space: ${avail_gb}GB available at $target, ${MIN_DISK_GB}GB required."
        echo "  Free up at least $((MIN_DISK_GB - avail_gb))GB and re-run ./setup."
        exit 1
    fi
    ok "Disk space ${avail_gb}GB available (need ${MIN_DISK_GB}GB)"
}

# ───────────────────────── Docker memory allocation (macOS) ──────────────
# On macOS, Docker Desktop runs in a VM with a configured RAM cap. The
# AuditLens stack (forwarder + api + postgres + grafana + prometheus)
# does not fit comfortably below 2GB. This check is macOS-only; on Linux
# `docker info` reports host RAM which is not user-configurable from the
# Docker side, so warning the operator there isn't useful.
ensure_docker_memory() {
    [ "$OS" = "macos" ] || return 0
    local mem_bytes
    mem_bytes=$(docker info --format '{{.MemTotal}}' 2>/dev/null)
    [[ "$mem_bytes" =~ ^[0-9]+$ ]] || return 0
    if [ "$mem_bytes" -lt 1073741824 ]; then  # < 1 GB
        fail "Docker has less than 1GB RAM allocated."
        echo "  AuditLens needs at least 2GB for all containers."
        echo "  Increase in Docker Desktop → Settings → Resources → Memory."
        exit 1
    elif [ "$mem_bytes" -lt 2147483648 ]; then  # < 2 GB
        warn "Docker has less than 2GB RAM allocated."
        echo "  AuditLens needs at least 2GB for all containers."
        echo "  Increase in Docker Desktop → Settings → Resources → Memory."
    else
        local mem_gb
        mem_gb=$(( mem_bytes / 1073741824 ))
        ok "Docker memory ${mem_gb}GB allocated"
    fi
}

# ───────────────────────── Port availability (soft, ask to continue) ─────
ensure_ports() {
    local conflicts=()
    for p in "${REQUIRED_PORTS[@]}"; do
        if command -v lsof >/dev/null 2>&1; then
            if lsof -nP -iTCP:"$p" -sTCP:LISTEN >/dev/null 2>&1; then
                conflicts+=("$p")
            fi
        elif command -v ss >/dev/null 2>&1; then
            if ss -ltn "sport = :$p" 2>/dev/null | grep -q ":$p\b"; then
                conflicts+=("$p")
            fi
        fi
    done
    if [ ${#conflicts[@]} -eq 0 ]; then
        ok "Ports ${REQUIRED_PORTS[*]} available"
        return 0
    fi
    warn "Port(s) already in use: ${conflicts[*]}"
    echo "  AuditLens needs ports ${REQUIRED_PORTS[*]} for Caddy + forwarder."
    if [ "$(prompt_yn "Continue anyway?" N)" != "Y" ]; then
        echo "  Free the port(s) and re-run ./setup."
        exit 1
    fi
}

# ───────────────────────── .env bootstrap (FIX 5) ────────────────────────
# Seed .env from .env.example on first run. Never overwrite an existing .env —
# operators commonly hand-edit credentials and we must not blow that away.
ensure_env_file() {
    local target="$SCRIPT_DIR/.env"
    local source="$SCRIPT_DIR/.env.example"
    if [ -f "$target" ]; then
        info ".env already present — leaving it alone."
        return 0
    fi
    if [ ! -f "$source" ]; then
        warn ".env not found and .env.example missing — create .env manually before starting AuditLens."
        return 0
    fi
    cp "$source" "$target"
    # Normal-flow message: the wizard owns credential entry from here on.
    # The skip-setup banner (printed by bootstrap_auditlens.py) tells operators
    # who want to bypass the wizard which fields to edit by hand — duplicating
    # that warning here is what made first-time users think they had to edit
    # the file before the wizard would proceed.
    ok "Created .env — the wizard will fill in your credentials."
}

# ───────────────────────── Python dependencies (FIX 1) ───────────────────
# Create a virtualenv with the verified python3.11+ interpreter and install
# requirements-setup.txt before handing off to the bootstrap installer.
#
# IMPORTANT: the host venv installs ONLY the wizard's direct deps
# (confluent-kafka for Kafka validation, PyYAML for --config-file mode).
# The production app (forwarder/api/frontend) runs inside Docker and uses
# requirements.txt — that heavier dep set never touches the host. This
# split keeps `./setup` fast and lets it succeed on bleeding-edge Pythons
# (3.14+) where pandas/numpy/pyarrow haven't shipped wheels yet.
ensure_python_deps() {
    local venv_dir="$SCRIPT_DIR/.venv"
    local req="$SCRIPT_DIR/requirements-setup.txt"
    if [ ! -f "$req" ]; then
        warn "requirements-setup.txt not found at $req — skipping dep install; bootstrap may fail."
        return 0
    fi
    if [ ! -x "$venv_dir/bin/python" ]; then
        info "Creating virtualenv at $venv_dir using ${PYTHON}…"
        if ! "$PYTHON" -m venv "$venv_dir"; then
            fail "Failed to create virtualenv. The python-venv package may be missing."
            case "$OS" in
                ubuntu|debian) echo "  Try: sudo apt-get install -y python3.11-venv" ;;
                amzn|rhel)     echo "  Try: sudo dnf install -y python3.11-pip" ;;
                macos)         echo "  Reinstall python via: brew reinstall python@3.11" ;;
            esac
            exit 1
        fi
    else
        info "Virtualenv already present at $venv_dir."
    fi
    # Switch the bootstrap interpreter to the venv copy so module-level
    # imports in scripts/bootstrap_auditlens.py resolve.
    PYTHON="$venv_dir/bin/python"

    # Re-read the Python version from the *venv* binary, not from the system
    # interpreter that check_python originally probed. They can diverge when
    # a previous run created the venv with python3.14 and the current shell's
    # `python3` is 3.13 (or vice-versa) — in that case PYTHON_VERSION_STR
    # reflects the system Python and would make the dep-compat gate test the
    # wrong wheel set. The venv binary is the only honest source of truth
    # for which interpreter pip is about to use.
    local VENV_PYTHON="$venv_dir/bin/python3"
    local VENV_PYTHON_VERSION VENV_MINOR
    VENV_PYTHON_VERSION=$("$VENV_PYTHON" --version 2>&1 | awk '{print $2}')
    VENV_MINOR=$("$VENV_PYTHON" -c "import sys; print(sys.version_info.minor)" 2>/dev/null)
    if [ -z "$VENV_PYTHON_VERSION" ] || [ -z "$VENV_MINOR" ]; then
        fail "Could not determine Python version from $VENV_PYTHON."
        exit 1
    fi
    if [ "$VENV_PYTHON_VERSION" != "$PYTHON_VERSION_STR" ]; then
        info "Venv Python ${VENV_PYTHON_VERSION} differs from system Python ${PYTHON_VERSION_STR} — gating on the venv interpreter."
    fi

    # Dynamic compatibility gate: for Python minor > PYTHON_MAX_TESTED_MINOR,
    # run `pip install --dry-run --only-binary=:all:` against
    # requirements-setup.txt and bail early with a clear "use Python 3.12 or
    # 3.13" message if any wheel is missing. Below the ceiling this is a
    # no-op. The dry-run shares its pip-upgrade step with the real install
    # below, so we only pay the `pip install --upgrade pip` cost once.
    check_python_dep_compat "$venv_dir" "$req" "$VENV_PYTHON_VERSION" "$VENV_MINOR"

    info "Installing Python dependencies (this can take a minute)…"
    # Best-effort pip upgrade — old pip can trip on modern wheel resolvers.
    # Skipped automatically if check_python_dep_compat already upgraded it.
    if ! "$venv_dir/bin/pip" install -q --upgrade pip >/dev/null 2>&1; then
        warn "pip self-upgrade failed (non-fatal) — continuing with bundled pip."
    fi
    if ! "$venv_dir/bin/pip" install -q -r "$req"; then
        fail "pip install -r requirements-setup.txt failed."
        echo "  Re-run with verbose output for details:"
        echo "    $venv_dir/bin/pip install -r $req"
        exit 1
    fi
    ok "Python dependencies installed."
}

# ───────────────────────── Main flow ─────────────────────────────────────
main() {
    detect_os
    if [ "$OS" = "windows" ]; then
        echo ""
        echo "╔══════════════════════════════════════╗"
        echo "║        AuditLens Setup               ║"
        echo "╚══════════════════════════════════════╝"
        echo ""
        warn "Windows detected (Git Bash)."
        echo "    AuditLens setup requires WSL2 for full compatibility."
        echo ""
        echo "    Quick setup:"
        echo "      1. Install WSL2: wsl --install (run in PowerShell as Admin)"
        echo "      2. Open Ubuntu from Start Menu"
        echo "      3. Clone and run:"
        echo "         git clone https://github.com/jegan-confluent/auditlens"
        echo "         cd auditlens && ./setup"
        echo ""
        echo "    Alternatively, Docker Desktop for Windows with WSL2 backend"
        echo "    is required for containers to work correctly."
        echo ""
        echo "    Press Enter to attempt setup anyway (may fail), or Ctrl-C to exit."
        # /dev/tty fallback for piped invocations; existing convention in
        # prompt_yn earlier in this file.
        if [ -r /dev/tty ]; then
            read -r _windows_ack </dev/tty || exit 1
        else
            read -r _windows_ack || exit 1
        fi
        unset _windows_ack
    fi
    print_banner

    ensure_python
    ensure_docker
    ensure_compose
    ensure_git
    ensure_disk
    ensure_docker_memory
    ensure_ports

    echo ""
    echo "Continuing setup..."
    echo ""

    ensure_env_file
    ensure_python_deps

    # Hand off to the guided installer.
    # PYTHONPATH must include the repo root so `scripts.bootstrap_auditlens`
    # resolves regardless of the user's cwd. PYTHON now points at the venv
    # interpreter populated by ensure_python_deps so module-level imports
    # in bootstrap (orjson, fastapi, etc.) resolve on a fresh clone.
    PYTHONPATH="$SCRIPT_DIR${PYTHONPATH:+:$PYTHONPATH}" \
        exec "$PYTHON" "$SCRIPT_DIR/scripts/bootstrap_auditlens.py" "$@"
}

main "$@"
