# ============================================================================
# Offset Strategy Examples - Copy these to your .env file
# ============================================================================

# ----------------------------------------------------------------------------
# EXAMPLE 1: Normal Operation (Default)
# ----------------------------------------------------------------------------
# Use Case: Normal restarts, production default
# No configuration needed - this is the default behavior

# OFFSET_STRATEGY=committed  # Optional, this is the default


# ----------------------------------------------------------------------------
# EXAMPLE 2: Skip Backlog After Extended Downtime
# ----------------------------------------------------------------------------
# Use Case: Forwarder was down for 2 weeks, 100GB backlog accumulated
# Goal: Skip backlog and catch up quickly

OFFSET_STRATEGY=latest


# ----------------------------------------------------------------------------
# EXAMPLE 3: Full Reprocessing for Compliance Audit
# ----------------------------------------------------------------------------
# Use Case: SOX audit requires all events from last 90 days
# Goal: Reprocess entire topic history

OFFSET_STRATEGY=earliest


# ----------------------------------------------------------------------------
# EXAMPLE 4: Disaster Recovery from Known-Good Point
# ----------------------------------------------------------------------------
# Use Case: Data corruption detected on Feb 15, last known-good was Feb 1
# Goal: Replay all events from Feb 1 onwards

OFFSET_STRATEGY=timestamp
OFFSET_TIMESTAMP=2025-02-01T00:00:00Z


# ----------------------------------------------------------------------------
# EXAMPLE 5: Reprocess Last 24 Hours After Bug Fix
# ----------------------------------------------------------------------------
# Use Case: Classification bug fixed, need to reprocess recent events
# Goal: Replay last 24 hours with corrected logic

OFFSET_STRATEGY=timestamp
OFFSET_HOURS_AGO=24


# ----------------------------------------------------------------------------
# EXAMPLE 6: Reprocess Last 7 Days (Gradual Catchup)
# ----------------------------------------------------------------------------
# Use Case: Forwarder down for 30 days, only need last 7 days
# Goal: Process last week of events, skip older backlog

OFFSET_STRATEGY=timestamp
OFFSET_HOURS_AGO=168  # 7 days = 168 hours


# ----------------------------------------------------------------------------
# EXAMPLE 7: Dry Run Testing (Safe Testing)
# ----------------------------------------------------------------------------
# Use Case: Test offset reset before applying to production
# Goal: Preview changes without applying them

OFFSET_STRATEGY=earliest  # Or any other strategy
OFFSET_DRY_RUN=true


# ----------------------------------------------------------------------------
# EXAMPLE 8: Multi-Week Catchup Strategy (Incremental)
# ----------------------------------------------------------------------------
# Use Case: 60-day downtime, incremental catchup to avoid overload
# Goal: Process 1 week at a time

# Week 1: Process events from 60-53 days ago
OFFSET_STRATEGY=timestamp
OFFSET_TIMESTAMP=2024-12-11T00:00:00Z  # 60 days ago
# Wait for catchup, then update:

# Week 2: Process events from 53-46 days ago
OFFSET_TIMESTAMP=2024-12-18T00:00:00Z  # 53 days ago
# Continue incrementally...


# ----------------------------------------------------------------------------
# EXAMPLE 9: Different Strategies for Different Environments
# ----------------------------------------------------------------------------

# Production: Always use committed (safe)
# OFFSET_STRATEGY=committed

# Staging: Reprocess last 24h for testing
# OFFSET_STRATEGY=timestamp
# OFFSET_HOURS_AGO=24

# Development: Full reprocessing for testing
# OFFSET_STRATEGY=earliest


# ----------------------------------------------------------------------------
# EXAMPLE 10: Emergency Rollback
# ----------------------------------------------------------------------------
# Use Case: Accidentally set wrong strategy, need to rollback
# Goal: Return to normal operation

# Remove all offset strategy configs:
# Comment out or delete these lines:
# OFFSET_STRATEGY=...
# OFFSET_TIMESTAMP=...
# OFFSET_HOURS_AGO=...
# OFFSET_DRY_RUN=...

# Forwarder will use default (committed) on next restart
