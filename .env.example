# =========================================================
# AuditLens v1.0.0 — REAL KAFKA TEST CONFIG
# =========================================================

# Production — set your domain here (Caddy handles HTTPS automatically)
AUDITLENS_DOMAIN=auditlens.yourcompany.com
# AuditLens needs TWO Kafka cluster configs for real testing:
#
# A. AUDIT SOURCE CLUSTER
#    This is the Confluent Cloud audit-log cluster.
#    AuditLens consumes from this cluster/topic.
#
# B. DESTINATION TEST CLUSTER
#    This is the workload/destination cluster where you create/delete test topics.
#    Those actions generate audit events that appear in the audit-log source cluster.
# =========================================================

# =========================================================
# 🔴 REQUIRED — Audit Log Source Cluster
# This cluster contains the Confluent audit log topic.
# Default topic is usually correct:
# confluent-audit-log-events
# =========================================================
AUDIT_BOOTSTRAP=
AUDIT_API_KEY=
AUDIT_API_SECRET=
AUDIT_TOPIC=confluent-audit-log-events

# GROUP_ID identifies the AuditLens Kafka consumer group.
GROUP_ID=auditlens-forwarder-v1

# Use earliest for first install/test if you want retained audit history.
# Use latest only if you want new events after startup.
AUTO_OFFSET_RESET=earliest

# =========================================================
# 🔴 REQUIRED — Destination Test Cluster
# Create/delete test topics in this cluster.
# These actions generate audit logs in the AUDIT source cluster.
# =========================================================
DEST_BOOTSTRAP=
DEST_API_KEY=
DEST_API_SECRET=

# =========================================================
# Kafka security defaults
# =========================================================
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN

# =========================================================
# 🚀 QUICK START (REAL TEST)
# =========================================================
# 1. Fill AUDIT_* values.
# 2. Fill DEST_* values.
# 3. Keep AUDIT_TOPIC as confluent-audit-log-events unless
#    `confluent audit-log describe` shows a different topic.
# 4. Keep GROUP_ID as auditlens-forwarder-v1.
# 5. Use AUTO_OFFSET_RESET=earliest for first test.
# 6. Run:
#    scripts/run_postgres_product.sh
# 7. Create/delete a test topic in the DEST cluster.
# 8. Open:
#    http://127.0.0.1:3000/events
# =========================================================

# =========================================================
# 🧠 HOW REAL TESTING WORKS
# =========================================================
# DEST cluster -> create/delete topic
# Confluent audit logging -> emits audit event
# AUDIT source cluster -> AuditLens consumes confluent-audit-log-events
# DB/API/UI -> event appears in AuditLens
# =========================================================

# =========================================================
# 🧠 OPTIONAL — Advanced settings (leave as-is)
# =========================================================

# =========================================================
# 💾 DATABASE
# SQLite is used for demo mode
# Postgres is used in product mode
# =========================================================
DATABASE_URL=sqlite:///./data/auditlens_api.db
FORWARDER_DATABASE_URL=sqlite:///./data/auditlens_api.db

# PostgreSQL password — REQUIRED when using postgres/dev profile.
#
# Storage posture (as of the docker-secrets migration):
#   - The postgres container reads the password from a Docker secret
#     file (./secrets/postgres_password.txt) via POSTGRES_PASSWORD_FILE,
#     so the value is NOT visible to `docker inspect auditlens-postgres`.
#   - The api container and postgres-exporter still read DATABASE_URL /
#     DATA_SOURCE_NAME from .env, which interpolates ${POSTGRES_PASSWORD}.
#   - The wizard's _ensure_host_directories() keeps the .env value and
#     the secret file in sync. On a clean install it auto-generates a
#     32-char alphanumeric password; on an upgrade it preserves the
#     existing value so the running postgres data volume keeps
#     authenticating.
#
# Postgres connection pool (api: 5 + 10 overflow, forwarder: varies,
# exporter: 1). The postgres container runs infra/postgres/tune.sh as
# its entrypoint, which exec's postgres with -c max_connections=200
# plus container-RAM-aware shared_buffers / effective_cache_size /
# work_mem / wal_buffers values.
POSTGRES_PASSWORD=   # REQUIRED — set a strong password before running

# Legacy SQLite "hot cache" alongside the main DB. In product mode (when
# DATABASE_URL is Postgres) the hot cache is redundant — Postgres is the
# store of truth — so the default `auto` disables it. Set `true` only for
# debug, and `false` to disable everywhere.
#   auto  = disabled when DATABASE_URL is postgresql:// (product mode)
#   true  = always enable (demo / debug only — pays for two stores)
#   false = always disable
ENABLE_SQLITE_HOT_CACHE=auto

# =========================================================
# ⚙️ FORWARDER SETTINGS
# (You don’t need to change these)
# =========================================================
ENABLE_DB_WRITER=true
DB_WRITE_BATCH_SIZE=100
DB_WRITE_FLUSH_INTERVAL_SECONDS=2
DB_WRITE_BACKOFF_MAX_SECONDS=60
EVENT_RETENTION_DAYS=7
RAW_PAYLOAD_RETENTION_DAYS=7
NOISE_RETENTION_DAYS=3
DB_RETENTION_CLEANUP_INTERVAL_SECONDS=3600
KAFKA_CONSUME_BATCH_SIZE=100
METRICS_PORT=8003

# Priority-queue sizing — buffers between processor and async DB writers.
# Defaults below are tuned for a single 8 GB VM (~55 MB total at full).
# Bump these higher only if you also have headroom on the VM.
RECORD_QUEUE_SIZE=10000
WRITER_CRITICAL_QUEUE_SIZE=500
WRITER_NORMAL_QUEUE_SIZE=5000
WRITER_BULK_QUEUE_SIZE=200000
WRITER_CATALOG_QUEUE_SIZE=10000

# Short-circuit bulk-noise events (mds.Authorize, kafka.Fetch, kafka.Produce, …)
# at the consume point. They go straight to the bulk writer, bypassing
# flatten_audit, the seven canonical Kafka produces, anomaly tracking, and
# the SQLite hot cache — saves the processor thread from doing ~83% of its
# work. Set to false only for debugging the full pipeline path.
ENABLE_NOISE_SHORT_CIRCUIT=true
# How long the processor waits for the bulk writer to persist short-circuited
# noise events before declining to commit. On timeout, the offset is NOT
# committed and the events replay on next start (no silent loss).
NOISE_PERSIST_WAIT_TIMEOUT_SECONDS=60.0

# =========================================================
# 🌐 UI + API
# =========================================================
# Frontend → API base URL, baked into the Next.js bundle at build time.
# Relative '/api' lets Caddy on :80 reverse-proxy to api:8080 and works
# on every platform (macOS, Linux EC2, Windows WSL2). Override to a full
# URL (e.g. http://127.0.0.1:8080) only when running without Caddy.
NEXT_PUBLIC_API_BASE_URL=/api
BACKEND_PORT=8080
FRONTEND_PORT=3000
# Caddy non-privileged fallback port. Defaults to 8088 — useful on macOS
# when :80 is already taken by something else on the host.
CADDY_FALLBACK_PORT=8088

# =========================================================
# 🔓 LOCAL DEV SETTINGS
# =========================================================
# Local dev only: set API_AUTH_ENABLED=false to bypass auth.
# Never disable auth in a deployment environment.
API_AUTH_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO

# =========================================================
# 🪪 IAM / PRINCIPAL ENRICHMENT
# Local v1 uses manual mapping first and falls back safely.
# Confluent IAM/Admin lookup is optional and only runs when enabled.
# Metrics correlation is advisory only and never treated as identity truth unless labels prove it.
# =========================================================
IAM_ENRICHMENT_ENABLED=false
IAM_ENRICHMENT_SOURCE=manual,confluent_api,metrics
IAM_ENRICHMENT_CACHE_TTL_SECONDS=3600
IAM_MAPPING_FILE=data/iam_mapping.json
METRICS_ENRICHMENT_ENABLED=false
METRICS_ENRICHMENT_SOURCE=correlation
METRICS_ENRICHMENT_CACHE_TTL_SECONDS=3600
CONFLUENT_CLOUD_API_KEY=
CONFLUENT_CLOUD_API_SECRET=
CONFLUENT_API_BASE_URL=https://api.confluent.cloud

# Optional: Confluent Schema Registry — enables Avro serialization for
# audit.enriched.v1 and audit.noise.v1. Leave empty to use JSON production.
SCHEMA_REGISTRY_URL=
SCHEMA_REGISTRY_API_KEY=
SCHEMA_REGISTRY_API_SECRET=
FORWARDER_HEALTH_URL=http://auditlens-forwarder:8003/health

# Optional: path to actor_mappings.yml for manual ID → name overrides.
# Loaded on startup and reloaded on mtime change. Mapped IDs take
# priority over IAM API resolution.
# ACTOR_MAPPINGS_FILE=actor_mappings.yml

# =========================================================
# 🔔 NOTIFICATIONS (slack / teams / webhook)
# Configurable per-destination filters live in notifications.yml.
# Copy notifications.example.yml → notifications.yml and edit.
# Inside Docker, mount notifications.yml into /app or set
# NOTIFICATIONS_CONFIG to a path under /run/secrets/ and place
# the file in ./secrets/.
# =========================================================
NOTIFICATIONS_CONFIG=notifications.yml

# Migration switch for the legacy hard-coded SLACK_WEBHOOK path.
#   auto  = disabled when notifications.yml provides destinations (default)
#   true  = always enable (backward compat)
#   false = always disable (notifier-only)
ENABLE_LEGACY_SLACK_WEBHOOK=auto

# Encryption key for app_settings secrets (AES-256-GCM).
# Generate: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# SETTINGS_ENCRYPTION_KEY=<generated>

# Grafana admin password — Change before any network exposure.
#
# Same storage posture as POSTGRES_PASSWORD above: the grafana container
# reads from a Docker secret (./secrets/grafana_admin_password.txt) via
# GF_SECURITY_ADMIN_PASSWORD__FILE, so `docker inspect audit-grafana` no
# longer exposes the value. The wizard syncs .env and the secret file.
GRAFANA_ADMIN_PASSWORD=changeme

# Streamlit dashboard password (profiles: streamlit, dev).
# If unset, the password gate is skipped (convenient for local dev).
# Set before running with --profile streamlit in any shared environment.
# STREAMLIT_PASSWORD=

# =========================================================
# 🗄️ POSTGRES — when running with --profile postgres or --profile dev
# =========================================================
# Compose has safe defaults for DB name and user; password is REQUIRED above.
POSTGRES_DB=auditlens
POSTGRES_USER=auditlens
POSTGRES_PORT=5432

# =========================================================
# 📤 INTERNAL KAFKA TOPICS — produced to DEST cluster
# These are the topic names the forwarder publishes to. Defaults are fine
# unless your destination cluster uses different topic naming.
# =========================================================
AUDIT_RAW_TOPIC=audit.raw.v1
AUDIT_NORMALIZED_TOPIC=audit.normalized.v1
AUDIT_ENRICHED_TOPIC=audit.enriched.v1
AUDIT_SIGNALS_DENIALS_TOPIC=audit.signals.denials.v1
AUDIT_SIGNALS_HIGHRISK_TOPIC=audit.signals.highrisk.v1
AUDIT_ALERTS_TOPIC=audit.alerts.v1
DLQ_TOPIC=audit.dlq.v1
# High-risk alerts gate: produce per-event high-risk alerts even when
# the denial aggregator is active.
ALERT_ON_HIGH_RISK=true

# =========================================================
# 🔧 BACKEND API TUNING — usually leave defaults
# =========================================================
# Path to a JSON file holding API auth tokens. Only used when API_AUTH_ENABLED=true.
API_AUTH_TOKEN_FILE=/run/secrets/auditlens-api-tokens.json
# Caps applied to /events list and export endpoints.
API_MAX_SEARCH_RESULTS=500
API_EXPORT_MAX_ROWS=5000
API_EXPORT_MAX_HOURS=168

# Optional general Confluent REST credentials (separate from the IAM key
# above). Empty defaults → backend falls back to CONFLUENT_CLOUD_API_KEY.
CONFLUENT_API_KEY=
CONFLUENT_API_SECRET=

# Public dashboard URL used in notification digests + outbound messages.
# Empty → digest omits the dashboard link section.
DASHBOARD_URL=

# Path the API + notifier read for destination config. Override if you
# mount notifications.yml at a non-default location.
NOTIFICATIONS_CONFIG_PATH=notifications.yml

# =========================================================
# 🔁 CONSUMER + KAFKA RETRY TUNING — leave defaults unless tuning
# =========================================================
CONSUMER_POLL_TIMEOUT_SECONDS=2.0
CONSUMER_EMPTY_POLL_SLEEP_SECONDS=0.25
CONSUMER_BATCH_SLEEP_SECONDS=0.25
KAFKA_RETRY_INITIAL_BACKOFF_SECONDS=1.0
KAFKA_RETRY_MAX_BACKOFF_SECONDS=60.0
# librdkafka internal queue caps. Tune up on high-throughput clusters.
KAFKA_QUEUED_MAX_MESSAGES_KBYTES=65536
KAFKA_PRODUCER_QUEUE_MAX_KBYTES=65536

# =========================================================
# 💾 FORWARDER LOCAL SQLITE PERSISTENCE
# Legacy buffer next to the main DB. In product (Postgres) mode the
# main DB is the store of truth, so these mostly run as a small cache.
# =========================================================
PERSISTENCE_ENABLED=true
PERSISTENCE_BACKEND=sqlite
FORWARDER_PERSISTENCE_DB_PATH=/app/data/auditlens.db
PERSISTENCE_DB_MAX_BYTES=1073741824     # 1 GiB
PERSISTENCE_WAL_MAX_BYTES=134217728     # 128 MiB
PERSISTENCE_ENRICHED_RETENTION_DAYS=3
PERSISTENCE_SIGNALS_RETENTION_DAYS=7
PERSISTENCE_ALERTS_RETENTION_DAYS=14
PERSISTENCE_AUDIT_RETENTION_DAYS=14

# Forwarder memory budget (MB) — informational; compose enforces the cgroup.
MEMORY_LIMIT_MB=512

# =========================================================
# 📊 MONITORING — Prometheus + Grafana
# =========================================================
GF_ADMIN_USER=admin
PROMETHEUS_RETENTION_TIME=7d
PROMETHEUS_RETENTION_SIZE=1GB

# =========================================================
# 🧠 MCP SERVER (optional — runs under the `future` compose profile)
# Token-protected HTTP endpoint exposing AuditLens to AI agents.
# =========================================================
MCP_PORT=8089
MCP_AUTH_TOKEN=

# =========================================================
# ❄️ COLD STORAGE — archive aged events to S3 / GCS before retention delete
# Leave blank to disable cold storage entirely (events are deleted at
# retention without archive). Required only if you want long-term retention.
# =========================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
GCS_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# =========================================================
# 🔐 KAFKA SECURITY — alternate names used by the MCP server.
# Mirror the KAFKA_SECURITY_PROTOCOL / KAFKA_SASL_MECHANISM above.
# =========================================================
SECURITY_PROTOCOL=SASL_SSL
SASL_MECHANISM=PLAIN

# Watchtower — auto-pull updated container images (seconds, default 5 min).
# Mostly a no-op today because the long-running services are either
# locally-built (forwarder/api/frontend) or digest-pinned (caddy/grafana/
# loki/promtail/alertmanager/postgres). Useful for future un-pinned deps.
WATCHTOWER_POLL_INTERVAL=300
