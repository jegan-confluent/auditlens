# =========================================================
# AuditLens v1.0.0 — REAL KAFKA TEST CONFIG
# =========================================================
# AuditLens needs TWO Kafka cluster configs for real testing:
#
# A. AUDIT SOURCE CLUSTER
#    This is the Confluent Cloud audit-log cluster.
#    AuditLens consumes from this cluster/topic.
#
# B. DESTINATION TEST CLUSTER
#    This is the workload/destination cluster where you create/delete test topics.
#    Those actions generate audit events that appear in the audit-log source cluster.
# =========================================================

# =========================================================
# 🔴 REQUIRED — Audit Log Source Cluster
# This cluster contains the Confluent audit log topic.
# Default topic is usually correct:
# confluent-audit-log-events
# =========================================================
AUDIT_BOOTSTRAP=
AUDIT_API_KEY=
AUDIT_API_SECRET=
AUDIT_TOPIC=confluent-audit-log-events

# GROUP_ID identifies the AuditLens Kafka consumer group.
GROUP_ID=auditlens-forwarder-v1

# Use earliest for first install/test if you want retained audit history.
# Use latest only if you want new events after startup.
AUTO_OFFSET_RESET=earliest

# =========================================================
# 🔴 REQUIRED — Destination Test Cluster
# Create/delete test topics in this cluster.
# These actions generate audit logs in the AUDIT source cluster.
# =========================================================
DEST_BOOTSTRAP=
DEST_API_KEY=
DEST_API_SECRET=

# =========================================================
# Kafka security defaults
# =========================================================
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN

# =========================================================
# 🚀 QUICK START (REAL TEST)
# =========================================================
# 1. Fill AUDIT_* values.
# 2. Fill DEST_* values.
# 3. Keep AUDIT_TOPIC as confluent-audit-log-events unless
#    `confluent audit-log describe` shows a different topic.
# 4. Keep GROUP_ID as auditlens-forwarder-v1.
# 5. Use AUTO_OFFSET_RESET=earliest for first test.
# 6. Run:
#    scripts/run_postgres_product.sh
# 7. Create/delete a test topic in the DEST cluster.
# 8. Open:
#    http://127.0.0.1:3000/events
# =========================================================

# =========================================================
# 🧠 HOW REAL TESTING WORKS
# =========================================================
# DEST cluster -> create/delete topic
# Confluent audit logging -> emits audit event
# AUDIT source cluster -> AuditLens consumes confluent-audit-log-events
# DB/API/UI -> event appears in AuditLens
# =========================================================

# =========================================================
# 🧠 OPTIONAL — Advanced settings (leave as-is)
# =========================================================

# =========================================================
# 💾 DATABASE
# SQLite is used for demo mode
# Postgres is used in product mode
# =========================================================
DATABASE_URL=sqlite:///./data/auditlens_api.db
FORWARDER_DATABASE_URL=sqlite:///./data/auditlens_api.db

# Legacy SQLite "hot cache" alongside the main DB. In product mode (when
# DATABASE_URL is Postgres) the hot cache is redundant — Postgres is the
# store of truth — so the default `auto` disables it. Set `true` only for
# debug, and `false` to disable everywhere.
#   auto  = disabled when DATABASE_URL is postgresql:// (product mode)
#   true  = always enable (demo / debug only — pays for two stores)
#   false = always disable
ENABLE_SQLITE_HOT_CACHE=auto

# =========================================================
# ⚙️ FORWARDER SETTINGS
# (You don’t need to change these)
# =========================================================
ENABLE_DB_WRITER=true
DB_WRITE_BATCH_SIZE=100
DB_WRITE_FLUSH_INTERVAL_SECONDS=2
DB_WRITE_BACKOFF_MAX_SECONDS=60
EVENT_RETENTION_DAYS=7
RAW_PAYLOAD_RETENTION_DAYS=7
NOISE_RETENTION_DAYS=3
DB_RETENTION_CLEANUP_INTERVAL_SECONDS=3600
KAFKA_CONSUME_BATCH_SIZE=100
METRICS_PORT=8003

# Priority-queue sizing — buffers between processor and async DB writers.
# Defaults below are tuned for a single 8 GB VM (~55 MB total at full).
# Bump these higher only if you also have headroom on the VM.
RECORD_QUEUE_SIZE=10000
WRITER_CRITICAL_QUEUE_SIZE=500
WRITER_NORMAL_QUEUE_SIZE=5000
WRITER_BULK_QUEUE_SIZE=200000
WRITER_CATALOG_QUEUE_SIZE=10000

# Short-circuit bulk-noise events (mds.Authorize, kafka.Fetch, kafka.Produce, …)
# at the consume point. They go straight to the bulk writer, bypassing
# flatten_audit, the seven canonical Kafka produces, anomaly tracking, and
# the SQLite hot cache — saves the processor thread from doing ~83% of its
# work. Set to false only for debugging the full pipeline path.
ENABLE_NOISE_SHORT_CIRCUIT=true
# How long the processor waits for the bulk writer to persist short-circuited
# noise events before declining to commit. On timeout, the offset is NOT
# committed and the events replay on next start (no silent loss).
NOISE_PERSIST_WAIT_TIMEOUT_SECONDS=60.0

# =========================================================
# 🌐 UI + API
# =========================================================
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
BACKEND_PORT=8080
FRONTEND_PORT=3000

# =========================================================
# 🔓 LOCAL DEV SETTINGS
# =========================================================
# Local dev only: set API_AUTH_ENABLED=false to bypass auth.
# Never disable auth in a deployment environment.
API_AUTH_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =========================================================
# 🪪 IAM / PRINCIPAL ENRICHMENT
# Local v1 uses manual mapping first and falls back safely.
# Confluent IAM/Admin lookup is optional and only runs when enabled.
# Metrics correlation is advisory only and never treated as identity truth unless labels prove it.
# =========================================================
IAM_ENRICHMENT_ENABLED=false
IAM_ENRICHMENT_SOURCE=manual,confluent_api,metrics
IAM_ENRICHMENT_CACHE_TTL_SECONDS=3600
IAM_MAPPING_FILE=data/iam_mapping.json
METRICS_ENRICHMENT_ENABLED=false
METRICS_ENRICHMENT_SOURCE=correlation
METRICS_ENRICHMENT_CACHE_TTL_SECONDS=3600
CONFLUENT_CLOUD_API_KEY=
CONFLUENT_CLOUD_API_SECRET=
CONFLUENT_API_BASE_URL=https://api.confluent.cloud
FORWARDER_HEALTH_URL=http://auditlens-forwarder:8003/health

# Optional: path to actor_mappings.yml for manual ID → name overrides.
# Loaded on startup and reloaded on mtime change. Mapped IDs take
# priority over IAM API resolution.
# ACTOR_MAPPINGS_FILE=actor_mappings.yml

# =========================================================
# 🔔 NOTIFICATIONS (slack / teams / webhook)
# Configurable per-destination filters live in notifications.yml.
# Copy notifications.example.yml → notifications.yml and edit.
# Inside Docker, mount notifications.yml into /app or set
# NOTIFICATIONS_CONFIG to a path under /run/secrets/ and place
# the file in ./secrets/.
# =========================================================
NOTIFICATIONS_CONFIG=notifications.yml

# Migration switch for the legacy hard-coded SLACK_WEBHOOK path.
#   auto  = disabled when notifications.yml provides destinations (default)
#   true  = always enable (backward compat)
#   false = always disable (notifier-only)
ENABLE_LEGACY_SLACK_WEBHOOK=auto

# Encryption key for app_settings secrets (AES-256-GCM).
# Generate: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# SETTINGS_ENCRYPTION_KEY=<generated>

# Grafana admin password — Change before any network exposure
GRAFANA_ADMIN_PASSWORD=changeme
