{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuditLens Enriched Audit Event (Tableflow-shaped)",
  "description": "Post-enrichment audit event. Mirrors the audit_events DB row + envelope metadata. This is the contract Tableflow surfaces as a queryable table — every field here is expected to land as a column.",
  "type": "object",
  "required": ["event_fingerprint"],
  "properties": {
    "schema_version": { "const": "audit.enriched.v1" },
    "pipeline_stage": { "const": "enriched" },
    "event_contract_version": { "type": "string" },
    "event_fingerprint": { "type": "string", "description": "Stable per-event hash. Tableflow row key." },
    "timestamp": { "type": ["string", "null"], "format": "date-time" },
    "result": { "type": ["string", "null"] },
    "actor": { "type": ["string", "null"] },
    "actor_id": { "type": ["string", "null"] },
    "actor_display_name": { "type": ["string", "null"] },
    "actor_email": { "type": ["string", "null"] },
    "actor_type": { "type": ["string", "null"] },
    "actor_source": { "type": ["string", "null"] },
    "actor_confidence": { "type": ["string", "null"] },
    "actor_enriched_at": { "type": ["string", "null"], "format": "date-time" },
    "action": { "type": ["string", "null"] },
    "normalized_action": { "type": ["string", "null"] },
    "action_category": { "type": ["string", "null"] },
    "resource_type": { "type": ["string", "null"] },
    "resource_name": { "type": ["string", "null"] },
    "resource_display": { "type": ["string", "null"] },
    "cluster_id": { "type": ["string", "null"] },
    "source_ip": { "type": ["string", "null"] },
    "environment_id": { "type": ["string", "null"] },
    "cluster_name": { "type": ["string", "null"] },
    "environment_name": { "type": ["string", "null"] },
    "signal_type": {
      "type": ["string", "null"],
      "enum": ["noise", "informational", "attention", "action_required", null]
    },
    "signal_reason": { "type": ["string", "null"] },
    "risk_level": {
      "type": ["string", "null"],
      "enum": ["informational", "low", "medium", "high", "critical", null]
    },
    "impact_type": { "type": ["string", "null"] },
    "change_type": { "type": ["string", "null"] },
    "event_title": { "type": ["string", "null"] },
    "event_summary": { "type": ["string", "null"] },
    "recommended_action": { "type": ["string", "null"] },
    "is_failure": { "type": ["boolean", "null"] },
    "is_denied": { "type": ["boolean", "null"] },
    "is_routine_noise": { "type": ["boolean", "null"] }
  },
  "additionalProperties": true
}
